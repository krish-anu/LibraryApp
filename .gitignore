.agents/
.claude/
skills-lock.json

# ===========================
# ENVIRONMENT FILES & SECRETS
# ===========================
.env
.env.local
.env.*
.env.*.local
*.env
!**/.env.example
!**/.env.*.example

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Misc
*.log
*.pid
*.seed
*.sqlite
*.sqlite3
*.db
*.dump
*_dump.sql
*.backup
.codex

