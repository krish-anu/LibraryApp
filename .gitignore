node_modules/
.pnpm-store/
.npm/
.next/
out/
*.tsbuildinfo
next-env.d.ts

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
env/

# Workspace-level cache/build artifacts
build/
coverage/
dist/
tmp/
.cache/
.turbo/

# Local environment helpers
.envrc

# Client local run config
client/Makefile
