# LibraryApp server production environment template
# Copy this file to .env.production for production-like runs.
# Never commit .env.production, private keys, or passwords.

# Runtime
ENVIRONMENT=production

# HTTP / CORS / proxy security
ALLOWED_ORIGINS=https://<admin-domain>
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY_HEADERS=true
TRUSTED_PROXY_CIDRS=

# Rate limiting / request size
DEFAULT_RATE_LIMIT=60/minute
AUTH_REGISTER_RATE_LIMIT=5/minute
AUTH_CREDENTIAL_LOGIN_RATE_LIMIT=10/minute
MAX_REQUEST_SIZE_BYTES=10485760

# Static assets
SERVE_LOCAL_ASSETS=false
ASSET_EXTENSION_ALLOWLIST=true
ALLOWED_ASSET_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif,.svg

# Database
# Choose one connection style:
# 1. DATABASE_URL, or
# 2. Direct DB_HOST/DB_PORT fields.
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://<db-user>:<db-password>@<db-host>:5432/libraryapp?sslmode=require

# Shared database credentials
DB_USER=
DB_PASSWORD=
DB_PASS=
DB_NAME=libraryapp

# Direct host-based PostgreSQL
DB_HOST=
DB_PORT=5432
DB_SSLMODE=require

# Asgardeo server-side authentication
ASGARDEO_BASE_URL=https://api.<region>.asgardeo.io/t/<org-name>
ASGARDEO_M2M_CLIENT_ID=
ASGARDEO_M2M_CLIENT_SECRET=
ASGARDEO_PUBLIC_CLIENT_ID=

# Admin authorization
# Admin-only API routes require one of these roles/groups/claims.
ADMIN_GROUPS=admin
# ADMIN_EMAILS=admin@example.com
