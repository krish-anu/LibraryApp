# LibraryApp server env templates
#
# Local development:
#   cp .env.local.example .env.local
#
# Production-like runs:
#   cp .env.production.example .env.production
#
# The server loads SERVER_ENV_FILE or ENV_FILE when set. Otherwise it loads
# .env.local if it exists, then falls back to .env for backward compatibility.
#
# Never commit real env files, private keys, passwords, or service-account JSON.
