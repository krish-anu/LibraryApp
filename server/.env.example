# Asgardeo Configuration
# Create an M2M (Machine-to-Machine) application in Asgardeo Console
# and add the credentials here

# Your Asgardeo organization URL
ASGARDEO_BASE_URL=https://api.eu.asgardeo.io/t/orgd2ib6

# M2M Application credentials (for user management from backend)
ASGARDEO_M2M_CLIENT_ID=your-m2m-client-id-here
ASGARDEO_M2M_CLIENT_SECRET=your-m2m-client-secret-here
