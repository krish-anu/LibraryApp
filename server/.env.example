# Firebase Admin / Firestore
FIREBASE_PROJECT_ID=libraryapp-eecd8
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@libraryapp-eecd8.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
# Optional alternative to the three values above:
# FIREBASE_SERVICE_ACCOUNT_JSON={"project_id":"...","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}

# Runtime environment
ENVIRONMENT=development

# CORS and proxy security
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Rate limiting and request size protection
DEFAULT_RATE_LIMIT=60/minute
AUTH_REGISTER_RATE_LIMIT=5/minute
AUTH_CREDENTIAL_LOGIN_RATE_LIMIT=10/minute
MAX_REQUEST_SIZE_BYTES=10485760

# Static asset serving
# In production, prefer false and serve assets via CDN/object storage.
SERVE_LOCAL_ASSETS=true
ASSET_EXTENSION_ALLOWLIST=false
ALLOWED_ASSET_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif,.svg

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Asgardeo Configuration
# Create an M2M (Machine-to-Machine) application in Asgardeo Console
# and add the credentials here

# Your Asgardeo organization URL
# Example: https://api.eu.asgardeo.io/t/<your-org-id>
ASGARDEO_BASE_URL=https://api.eu.asgardeo.io/t/<your-org-id>

# M2M application credentials used by backend-managed flows such as /auth/register
ASGARDEO_M2M_CLIENT_ID=your-m2m-client-id-here
ASGARDEO_M2M_CLIENT_SECRET=your-m2m-client-secret-here

# Public/native application client ID used by /auth/login/credentials
ASGARDEO_PUBLIC_CLIENT_ID=your-public-client-id-here
