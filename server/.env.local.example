# LibraryApp server local environment template
# Copy this file to .env.local for local development.
# Never commit .env.local, private keys, passwords, or service-account JSON files.

# Runtime
ENVIRONMENT=development

# HTTP / CORS / proxy security
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY_HEADERS=false
TRUSTED_PROXY_CIDRS=

# Rate limiting / request size
DEFAULT_RATE_LIMIT=60/minute
AUTH_REGISTER_RATE_LIMIT=5/minute
AUTH_CREDENTIAL_LOGIN_RATE_LIMIT=10/minute
MAX_REQUEST_SIZE_BYTES=10485760

# Static assets
SERVE_LOCAL_ASSETS=true
ASSET_EXTENSION_ALLOWLIST=false
ALLOWED_ASSET_EXTENSIONS=.jpg,.jpeg,.png,.webp,.gif,.svg

# Database
# Choose one connection style:
# 1. DATABASE_URL, or
# 2. Cloud SQL connector fields, or
# 3. Direct DB_HOST/DB_PORT fields.
DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://<db-user>:<db-password>@localhost:5432/<db-name>

# Shared database credentials
DB_USER=postgres
DB_PASSWORD=
DB_PASS=
DB_NAME=libraryapp-c781e-database

# Cloud SQL connector
INSTANCE_CONNECTION_NAME=libraryapp-c781e:us-central1:library-app
CLOUD_SQL_CONNECTION_NAME=libraryapp-c781e:us-central1:library-app
PRIVATE_IP=false

# The app can infer INSTANCE_CONNECTION_NAME from these Firebase SQL values.
FIREBASE_PROJECT_ID=libraryapp-c781e
GCP_PROJECT=libraryapp-c781e
FIREBASE_SQL_LOCATION=us-central1
FIREBASE_SQL_INSTANCE_ID=library-app
FIREBASE_SQL_SERVICE_ID=libraryapp-c781e-service

# Direct host-based PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=disable

# Firebase Admin / Firestore
# Prefer a local ignored JSON file for development.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Keep private-key newlines escaped if using .env.local:
# FIREBASE_PRIVATE_KEY="<escaped-private-key-with-newlines>"

# Local service-account JSON paths.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_FILE=
GOOGLE_APPLICATION_CREDENTIALS=

# Asgardeo server-side authentication
ASGARDEO_BASE_URL=https://api.<region>.asgardeo.io/t/<org-name>
ASGARDEO_M2M_CLIENT_ID=
ASGARDEO_M2M_CLIENT_SECRET=
ASGARDEO_PUBLIC_CLIENT_ID=
