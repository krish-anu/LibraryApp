# LibraryApp admin environment template
# Copy this file to .env.local for local development.
# Never commit .env.local, private keys, or client secrets.

# Runtime
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LIBRARY_API_BASE_URL=http://127.0.0.1:8000

# Asgardeo
ASGARDEO_CLIENT_ID=
ASGARDEO_CLIENT_SECRET=
ASGARDEO_AUTHORIZE_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/authorize
ASGARDEO_TOKEN_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/token
ASGARDEO_USERINFO_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/userinfo
ASGARDEO_LOGOUT_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oidc/logout
ASGARDEO_SCOPE="openid profile email"
ASGARDEO_PROMPT="login"

# Admin authorization
# Users must have one of these roles/groups/claims in Asgardeo userinfo or token claims.
ADMIN_GROUPS=admin
# ADMIN_EMAILS=admin@example.com
# Optional; defaults to ASGARDEO_CLIENT_SECRET when available.
# ADMIN_SESSION_SECRET=
