# LibraryApp admin environment template
# Copy this file to .env.local for local development.
# Never commit .env.local, private keys, client secrets, or service-account JSON.

# Runtime
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
LIBRARY_API_BASE_URL=http://127.0.0.1:8000

# Firebase Admin
# Prefer FIREBASE_SERVICE_ACCOUNT_JSON for deployments, or use the individual fields below.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Keep private-key newlines escaped if using .env.local:
# FIREBASE_PRIVATE_KEY="<escaped-private-key-with-newlines>"

# Asgardeo
ASGARDEO_CLIENT_ID=
ASGARDEO_CLIENT_SECRET=
ASGARDEO_AUTHORIZE_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/authorize
ASGARDEO_TOKEN_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/token
ASGARDEO_USERINFO_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oauth2/userinfo
ASGARDEO_LOGOUT_ENDPOINT=https://api.<region>.asgardeo.io/t/<org-name>/oidc/logout
ASGARDEO_SCOPE="openid profile email"
ASGARDEO_PROMPT="login"
